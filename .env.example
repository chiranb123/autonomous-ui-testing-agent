# ── GitHub ─────────────────────────────────────────────────────────────────
# Personal access token with read:project and repo scopes
GITHUB_TOKEN=ghp_your_token_here
GITHUB_OWNER=your_github_username
GITHUB_PROJECT_NUMBER=1
GITHUB_STATUS_FILTER=Ready For QA

# ── LLM Provider ───────────────────────────────────────────────────────────
# Options: groq (default, fast) | openrouter (fallback, many free models)
LLM_PROVIDER=groq

# Groq — https://console.groq.com
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter — https://openrouter.ai (used when LLM_PROVIDER=openrouter)
DEEPSEEK_API_KEY=sk-or-v1-your_key_here
DEEPSEEK_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ── Target Application ─────────────────────────────────────────────────────
START_URL=https://www.saucedemo.com/

# ── Application Credentials ────────────────────────────────────────────────
# Leave blank for demo sites (agent reads credentials from the page).
# Set explicitly for real applications.
VALID_USERNAME=
VALID_PASSWORD=
INVALID_PASSWORD=wrong_password_!!!

# ── Run Controls ───────────────────────────────────────────────────────────
MAX_SCENARIOS=0    # 0 = all; 1-N = cap per issue
FRESH=1            # 1 = regenerate everything; 0 = use cached LLM results
PYTHONUTF8=1       # Required on Windows to avoid UnicodeEncodeError

# ── Self-Heal / Robustness ─────────────────────────────────────────────────
LOCATE_RETRIES=3       # Max retries per click/type before giving up
LOCATE_BACKOFF=1.0     # Seconds between retries
CONTINUE_ON_FAILURE=1  # 1 = keep running after a step fails
SOFT_VERIFY=1          # 1 = verify failures are non-fatal (recorded, not aborted)
